{
  "manifest_version": 3,
  "name": "AI Chat Switcher",
  "version": "1.1.0",
  "description": "在 Gemini、豆包、GitHub Copilot 等 AI 网页之间快速切换",
  "permissions": ["activeTab", "tabs"],
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*",
        "https://github.com/copilot",
        "https://github.com/copilot/*",
        "https://copilot.microsoft.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}