{
  "manifest_version": 3,
  "name": "Edge AI Chat Switcher",
  "version": "1.0.0",
  "description": "Quickly switch between Gemini, Doubao, and Microsoft Copilot from any of the three AI chat sites.",

  "permissions": ["activeTab"],

  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Chat Switcher"
  },

  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://www.doubao.com/*",
        "https://copilot.microsoft.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
